{
  "name": "fellow-jobber",
  "version": "1.0.0",
  "description": "Fellow jobber is a scarping multiagent systems that finds the job which are a high match to the CV and fetches those jobs  (Germany) and mails them to your inbox. )",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "check": "tsc --noEmit",
    "build": "tsc",
    "dev": "adk web src",
    "agent": "adk run src/agent.ts",
    "validate-data": "tsx src/validate-data.ts",
    "test-retrieval": "tsx src/test-retrieval.ts",
    "test-render": "tsx src/test-render.ts",
    "test-azure-nlp": "tsx src/test-balanced-azure-nlp.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/my-fellow-agents/fellow-jobber.git"
  },
