  "bugs": {
    "url": "https://github.com/my-fellow-agents/fellow-jobber/issues"
  },
  "homepage": "https://github.com/my-fellow-agents/fellow-jobber#readme",
  "devDependencies": {
    "@google/adk-devtools": "^1.3.0",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@google/adk": "^1.3.0",
